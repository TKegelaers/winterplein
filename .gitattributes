# Normalize line endings to LF in the repository, convert to CRLF on Windows checkout
* text=auto eol=lf

# Explicitly handle common text file types
*.cs text eol=lf
*.csproj text eol=lf
*.sln text eol=lf
*.md text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.razor text eol=lf
*.html text eol=lf
*.css text eol=lf

# Binary files — no conversion
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.dll binary
*.exe binary

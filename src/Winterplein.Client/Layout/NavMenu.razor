@inject AppState AppState
@implements IDisposable

<MudNavMenu>
    <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Home">
        Home
    </MudNavLink>
    <MudNavLink Href="/players" Icon="@Icons.Material.Filled.People">
        <div class="d-flex align-center gap-2">
            Players
            @if (AppState.PlayerCount > 0)
            {
                <MudChip T="string" Size="Size.Small" Color="Color.Primary" Class="ml-1">
                    @AppState.PlayerCount
                </MudChip>
            }
        </div>
    </MudNavLink>
    <MudNavLink Href="/matches" Icon="@Icons.Material.Filled.SportsTennis">
        Matches
    </MudNavLink>
    <MudNavLink Href="/seasons" Icon="@Icons.Material.Filled.CalendarMonth">
        Seasons
    </MudNavLink>
</MudNavMenu>

@code {
    protected override void OnInitialized()
    {
        AppState.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        AppState.OnChange -= StateHasChanged;
    }
}

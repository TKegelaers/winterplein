@page "/seasons/{Id:int}/edit"
@using Winterplein.Shared.DTOs
@inject SeasonApiClient SeasonApi
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<MudText Typo="Typo.h5" Class="mb-4">Edit Season</MudText>

@if (_loading)
{
    <MudSkeleton />
}
else if (_season == null)
{
    <MudAlert Severity="Severity.Error">Season not found.</MudAlert>
}
else
{
    <MudPaper Class="pa-4" Elevation="2">
        <SeasonForm SubmitLabel="Save" InitialValues="_season"
                    OnSubmit="HandleSubmit" OnCancel="Cancel" />
    </MudPaper>
}

@code {
    [Parameter] public int Id { get; set; }

    private SeasonDto? _season;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _season = await SeasonApi.GetSeasonAsync(Id);
        }
        catch (Exception)
        {
            Snackbar.Add("Failed to load season.", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task HandleSubmit((string Name, DateOnly StartDate, DateOnly EndDate, DayOfWeek Weekday, TimeOnly StartHour, TimeOnly EndHour) values)
    {
        try
        {
            var request = new UpdateSeasonRequest(values.Name, values.StartDate, values.EndDate,
                values.Weekday, values.StartHour, values.EndHour);
            var updated = await SeasonApi.UpdateSeasonAsync(Id, request);
            if (updated == null)
            {
                Snackbar.Add("Season not found.", Severity.Error);
                return;
            }
            Snackbar.Add("Season updated.", Severity.Success);
            Navigation.NavigateTo($"/seasons/{Id}");
        }
        catch (Exception)
        {
            Snackbar.Add("Failed to update season.", Severity.Error);
        }
    }

    private void Cancel() => Navigation.NavigateTo($"/seasons/{Id}");
}
